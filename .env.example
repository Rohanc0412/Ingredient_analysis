# Copy this file to ".env" and fill in values.
# IMPORTANT: Never commit real API keys.

# OpenRouter / LLM configuration
OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# OPENROUTER_MODEL_EXTRACT=arcee-ai/trinity-large-preview:free
# OPENROUTER_MODEL_SUMMARY=arcee-ai/trinity-large-preview:free
# OPENROUTER_MAX_TOKENS=2000

# PAPER_PDF_ROOT=input/pdfs

# paper_extractor defaults (optional)
# PAPER_EXTRACT_TEMPLATE_XLSX=input/templates/weight_management_paper_extraction_template.xlsx
# PAPER_EXTRACT_OUTPUT_XLSX=output/paper_wise_analysis/paper_analysis.xlsx
# PAPER_EXTRACTOR_PDF_ROOT=input/pdfs
# PAPER_EXTRACTOR_MAX_INPUT_CHARS=30000
# Hard timeouts (seconds)
# PAPER_EXTRACTOR_PDF_EXTRACT_TIMEOUT_S=90
# PAPER_EXTRACTOR_PDF_PROCESS_TIMEOUT_S=600
# PAPER_SUMMARY_PDF_EXTRACT_TIMEOUT_S=90
# PAPER_SUMMARY_PDF_PROCESS_TIMEOUT_S=600
# PAPER_EXTRACTOR_SUMMARY_MIN_SENTENCES=110

# Extractor concurrency
# PAPER_EXTRACT_CALLS_PER_MIN=5
# PAPER_EXTRACT_MAX_INFLIGHT=2
# PAPER_EXTRACT_WORKERS=3
# PAPER_EXTRACTOR_EXTRACT_LLM_CALLS_PER_MINUTE=5
# PAPER_EXTRACTOR_LLM_CALLS_PER_MINUTE=5
# PAPER_EXTRACTOR_EXTRACT_LLM_MAX_INFLIGHT=2
# PAPER_EXTRACTOR_LLM_MAX_INFLIGHT=2
# PAPER_EXTRACTOR_EXTRACT_WORKERS=3
# PAPER_EXTRACTOR_WORKERS=3

# Summarizer concurrency
# PAPER_SUMMARY_CALLS_PER_MIN=5
# PAPER_SUMMARY_MAX_INFLIGHT=2
# PAPER_SUMMARY_WORKERS=3
# PAPER_EXTRACTOR_SUMMARY_LLM_CALLS_PER_MINUTE=5
# PAPER_EXTRACTOR_SUMMARY_LLM_MAX_INFLIGHT=2
# PAPER_EXTRACTOR_SUMMARY_WORKERS=3

# ingredient matrix defaults (optional)
# INGREDIENT_MATRIX_INPUT_DIR=input/ingredient_analysis
# INGREDIENT_MATRIX_TEMPLATE_XLSX=input/templates/matrix_weight_management.template.xlsx
# INGREDIENT_MATRIX_OUTPUT_XLSX=output/ingredient_wise_analysis/ingredient_matrix.xlsx

# Google Sheets export defaults (optional)
# GOOGLE_SHEETS_SOURCE_XLSX=output/ingredient_analysis_output.xlsx
# GOOGLE_OAUTH_CLIENT_SECRET_JSON=C:/path/to/oauth-client-secret.json
# GOOGLE_OAUTH_TOKEN_JSON=output/google_oauth_token.json
# GOOGLE_DRIVE_FOLDER_ID=

# Project logging defaults (optional)
# PROJECT_LOG_LEVEL=INFO
# PROJECT_LOG_TIMESTAMPS=false
# PROJECT_LOG_TO_FILE=false
# PROJECT_LOG_DIR=output/logs
