# Copy this file to ".env" and fill in values.
# IMPORTANT: Never commit real API keys or AWS credentials.

# -----------------------------------------------------------------------------
# LLM mode
# -----------------------------------------------------------------------------
# Valid values:
# - openrouter_only
# - bedrock_only
# - mixed
LLM_MODE=openrouter_only

# Used only when LLM_MODE=mixed.
# MIXED_MODE_PROVIDER_EXTRACT=openrouter
# MIXED_MODE_PROVIDER_SUMMARY=bedrock

# -----------------------------------------------------------------------------
# OpenRouter
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL_EXTRACT=arcee-ai/trinity-large-preview:free
# OPENROUTER_MODEL_SUMMARY=arcee-ai/trinity-large-preview:free
# OPENROUTER_MAX_TOKENS=2000
# OPENROUTER_MAX_TOKENS_SUMMARY=10000

# -----------------------------------------------------------------------------
# Amazon Bedrock
# -----------------------------------------------------------------------------
# To use Bedrock, change LLM_MODE to bedrock_only (or mixed) and fill in:
# BEDROCK_REGION=us-east-1
# BEDROCK_MODEL_EXTRACT=amazon.nova-lite-v1:0
# BEDROCK_MODEL_SUMMARY=amazon.nova-lite-v1:0
# BEDROCK_MAX_TOKENS=2000
# BEDROCK_MAX_TOKENS_SUMMARY=10000
#
# Authentication — use one of the two approaches below:
#
# Option A — named AWS profile (recommended):
# BEDROCK_AWS_PROFILE=<your_aws_profile>
#
# Option B — explicit credentials:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# -----------------------------------------------------------------------------
# PDF storage
# -----------------------------------------------------------------------------
# PAPER_PDF_ROOT=input/pdfs

# -----------------------------------------------------------------------------
# Paper extractor
# -----------------------------------------------------------------------------
# PAPER_EXTRACT_TEMPLATE_XLSX=input/templates/haleon_longevity_ingredient_template.xlsx
# PAPER_EXTRACT_OUTPUT_XLSX=output/paper_wise_analysis/longevity_paper_analysis.xlsx
# PAPER_EXTRACTOR_MAX_INPUT_CHARS=30000
# PAPER_EXTRACTOR_PDF_EXTRACT_TIMEOUT_S=90
# PAPER_EXTRACTOR_PDF_PROCESS_TIMEOUT_S=600
# PAPER_EXTRACTOR_SUMMARY_MIN_SENTENCES=110

# Extractor concurrency
# PAPER_EXTRACT_CALLS_PER_MIN=5
# PAPER_EXTRACT_MAX_INFLIGHT=2
# PAPER_EXTRACT_WORKERS=3

# -----------------------------------------------------------------------------
# Paper summarizer
# -----------------------------------------------------------------------------
# PAPER_SUMMARY_PDF_EXTRACT_TIMEOUT_S=90
# PAPER_SUMMARY_PDF_PROCESS_TIMEOUT_S=600

# Summarizer concurrency
# PAPER_SUMMARY_CALLS_PER_MIN=5
# PAPER_SUMMARY_MAX_INFLIGHT=2
# PAPER_SUMMARY_WORKERS=3

# -----------------------------------------------------------------------------
# Ingredient matrix
# -----------------------------------------------------------------------------
# INGREDIENT_MATRIX_INPUT_DIR=input/ingredient_analysis
# INGREDIENT_MATRIX_TEMPLATE_XLSX=input/templates/haleon_longevity_matrix_template.xlsx
# INGREDIENT_MATRIX_OUTPUT_XLSX=output/ingredient_wise_analysis/longevity_ingredient_matrix.xlsx

# -----------------------------------------------------------------------------
# Google Sheets export
# -----------------------------------------------------------------------------
# GOOGLE_SHEETS_SOURCE_XLSX=output/ingredient_analysis_output.xlsx
# GOOGLE_OAUTH_CLIENT_SECRET_JSON=C:/path/to/oauth-client-secret.json
# GOOGLE_OAUTH_TOKEN_JSON=output/google_oauth_token.json
# GOOGLE_DRIVE_FOLDER_ID=

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# PROJECT_LOG_LEVEL=INFO
# PROJECT_LOG_TIMESTAMPS=false
# PROJECT_LOG_TO_FILE=false
# PROJECT_LOG_DIR=output/logs

# -----------------------------------------------------------------------------
# Archive
# -----------------------------------------------------------------------------
# ARCHIVE_ROOT_DIR=D:/archives/ingredient_analysis
